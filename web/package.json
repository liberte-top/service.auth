{
  "name": "service-auth-web",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev --host --port 5173",
    "build": "svelte-kit sync && node ./scripts/write-version.mjs && vite build",
