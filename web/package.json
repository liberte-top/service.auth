    "start": "node build",
    "openapi:gen": "orval --config orval.config.ts"
  },
  "dependencies": {
    "@sveltejs/adapter-node": "5.2.12",
    "@sveltejs/kit": "2.17.1",
    "@liberte-top/components": "0.1.0",
    "@liberte-top/shared": "0.0.4-beta.1",
    "svelte": "5.38.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "4.0.0",
    "@types/node": "22.13.10",
    "orval": "8.1.0",
    "typescript": "5.6.3",
    "vite": "5.4.11"
  }
}
